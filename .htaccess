DirectoryIndex index.php

RewriteEngine On

# Internal rewrite of /{16-char hex} to ?id={16-char hex}.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([0-9a-f]{16})$ index.php?id=$1 [L,QSA]

# Whitelist: allow the entry point and root-level image assets, then stop.
RewriteRule ^index\.php$ - [L]
RewriteRule ^[^/]+\.(jpe?g|png|gif|svg|webp|ico)$ - [L]

# Anything not whitelisted above is forbidden. Covers subdirectories
# (src/, tests/, vendor/, .vscode/, .git/, etc.) and root-level files
# we don't want public (composer.json, README.md, CLAUDE.md, .htaccess,
# data.sqlite, etc.).
RewriteRule . - [F,L]
